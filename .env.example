# ============================================================
# Quikuvr5 - Docker UVR5 Quikseries — Environment Configuration
# ============================================================
# Copy this file to .env and adjust values for your deployment.
#
# IMPORTANT:
#   - Do NOT use variable interpolation (e.g. ${HOST_BASE}/models)
#     Docker Compose does not support it in .env files.
#   - APP_UID/APP_GID are used instead of UID/GID to avoid
#     conflicts with the bash built-in $UID.
# ============================================================

# -------- IMAGE & CONTAINER --------
IMAGE_NAME=uvr5-industrial
CONTAINER_NAME=uvr5

# -------- NETWORK --------
UVR_PORT=7860

# Bind address for the host-side port mapping.
# 0.0.0.0  = listen on all interfaces (LAN-accessible)
# 127.0.0.1 = localhost only (more secure)
BIND_ADDRESS=0.0.0.0

# -------- USER MAPPING --------
# Match these to the host user that owns the data directories.
# Run: id -u  and  id -g  to find your values.
APP_UID=1000
APP_GID=1000

# -------- FEATURES --------
USE_GPU=true
ENABLE_BUILD_TOOLS=false

# -------- RUNTIME --------
# Skip runtime import validation for faster container startup.
# Set to true once your image is stable to save 5-10s on each start.
SKIP_RUNTIME_VALIDATION=false

# -------- REPO SOURCE --------
# Git repository URL. Change to use a fork or alternative UVR5 repo.
# Must be a valid HTTPS or SSH git URL ending in .git
UVR5_GIT_REPO=https://github.com/Eddycrack864/UVR5-UI.git

# -------- REPO PINNING --------
# Pin UVR5-UI repo to a specific git tag, branch, or commit SHA.
# Leave empty to clone the latest default branch (main).
# For reproducible production builds, pin to a tag or full SHA.
# Examples:
#   UVR5_GIT_REF=v1.0.0          # release tag
#   UVR5_GIT_REF=main             # branch (not recommended for prod)
#   UVR5_GIT_REF=a1b2c3d4e5f6    # commit SHA (most reproducible)
UVR5_GIT_REF=v1.8.4

# -------- HOST VOLUME PATHS --------
# All paths must be absolute. Create them before first run.
HOST_MODELS=/data/uvr5/models
HOST_INPUTS=/data/uvr5/inputs
HOST_OUTPUTS=/data/uvr5/outputs
HOST_CACHE=/data/uvr5/cache
HOST_PIP_CACHE=/data/uvr5/pip-cache
HOST_WHEELS=/data/uvr5/wheels
